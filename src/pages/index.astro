---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import MainLayout from '../layouts/MainLayout.astro';
import {
	FEATURED_TOPICS,
	HOME_HIGHLIGHTS,
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_EMAIL,
	SITE_GITHUB,
	SITE_TITLE,
} from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.slice(0, 3);
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION} pageClass="home-page">
	<section class="hero-grid">
		<div class="hero-copy card-surface hero-panel">
			<p class="eyebrow">前端笔记与实现复盘</p>
			<h2>记录前端实现、样式系统与技术决策中的细节问题。</h2>
			<p class="hero-text">
				这里主要写 React、Astro、CSS、性能优化和组件设计。文章以问题导向的技术笔记为主，尽量把结论、上下文和取舍过程写清楚。
			</p>
			<div class="hero-actions">
				<a class="button button-primary" href="/blog">开始阅读</a>
				<a class="button button-secondary" href="/tags">按标签浏览</a>
			</div>
			<ul class="hero-stats" aria-label="站点信息">
				<li>
					<strong>{posts.length}</strong>
					<span>篇归档文章</span>
				</li>
				<li>
					<strong>RSS</strong>
					<span>可订阅更新</span>
				</li>
				<li>
					<strong>{SITE_AUTHOR}</strong>
					<span>作者与维护者</span>
				</li>
			</ul>
		</div>
		<div class="hero-aside stack-lg">
			<div class="card-surface tone-accent">
				<p class="eyebrow">当前主题</p>
				<ul class="topic-list">
					{FEATURED_TOPICS.map((topic) => <li>{topic}</li>)}
				</ul>
			</div>
			<div class="card-surface tone-warm">
				<p class="eyebrow">联系</p>
				<div class="contact-list compact-text">
					<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
					<a href={SITE_GITHUB} target="_blank" rel="noreferrer">GitHub / w1f666</a>
				</div>
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">编辑推荐</p>
				<h2>先从这篇开始</h2>
			</div>
			<a class="section-link" href="/blog">浏览全部文章</a>
		</div>
		{featuredPost && <ArticleCard post={featuredPost} variant="feature" />}
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">最近更新</p>
				<h2>新写下的几篇</h2>
			</div>
		</div>
		<div class="post-list">
			{latestPosts.map((post) => <ArticleCard post={post} />)}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">阅读偏好</p>
				<h2>这个博客想保留什么</h2>
			</div>
		</div>
		<div class="grid-3">
			{HOME_HIGHLIGHTS.map((item) => (
				<div class="card-surface info-card">
					<h3>{item.title}</h3>
					<p>{item.description}</p>
				</div>
			))}
		</div>
	</section>
</MainLayout>
