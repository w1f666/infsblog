---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="nav-shell">
		<a class="brand" href="/">
			<strong>{SITE_TITLE}</strong>
		</a>
		<nav aria-label="主导航">
			<div class="internal-links">
				{NAV_LINKS.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
			</div>
			<a class="feed-link" href="/rss.xml">RSS</a>
		</nav>
	</div>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(22px) saturate(150%);
		background: rgba(232, 238, 245, 0.46);
		border-bottom: 1px solid rgba(255, 255, 255, 0.3);
		box-shadow: 0 18px 40px rgba(19, 34, 51, 0.08);
	}
	.nav-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 16px 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		color: inherit;
		transition: transform 180ms ease, opacity 180ms ease;
	}
	.brand:hover {
		transform: translateY(-1px);
	}
	.brand strong {
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: lowercase;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 18px;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 6px;
	}
	nav a.active {
		background: rgba(255, 255, 255, 0.4);
		color: var(--ink);
		border-color: rgba(255, 255, 255, 0.44);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
	}
	.feed-link {
		padding: 0.7rem 1rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.32);
		text-decoration: none;
		color: var(--ink);
		font-size: 0.92rem;
		font-weight: 600;
		border: 1px solid rgba(255, 255, 255, 0.38);
		backdrop-filter: blur(18px) saturate(150%);
	}
	.feed-link:hover {
		transform: translateY(-1px);
		border-color: rgba(255, 255, 255, 0.5);
		box-shadow: 0 14px 26px rgba(19, 34, 51, 0.1);
	}
	@media (max-width: 820px) {
		.nav-shell,
		nav,
		.internal-links {
			flex-wrap: wrap;
		}
		.nav-shell {
			padding: 14px 0;
		}
		.feed-link {
			display: none;
		}
	}
</style>
