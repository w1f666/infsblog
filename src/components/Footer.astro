---
import { NAV_LINKS, SITE_AUTHOR, SITE_DESCRIPTION, SITE_EMAIL, SITE_GITHUB, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-shell">
		<div>
			<p class="footer-title">{SITE_TITLE}</p>
			<p class="footer-copy">{SITE_DESCRIPTION}</p>
		</div>
		<div class="footer-nav" aria-label="页脚导航">
			{NAV_LINKS.map((link) => (
				<a href={link.href}>{link.label}</a>
			))}
			<a href="/rss.xml">RSS</a>
		</div>
		<div class="footer-contact" aria-label="联系方式">
			<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
			<a href={SITE_GITHUB} target="_blank" rel="noreferrer">GitHub / w1f666</a>
		</div>
		<p class="footer-meta">© {today.getFullYear()} {SITE_AUTHOR}. Built with Astro.</p>
	</div>
</footer>
<style>
	footer {
		padding: 32px 0 56px;
	}
	.footer-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 32px;
		border-radius: 32px;
		background: rgba(255, 255, 255, 0.28);
		border: 1px solid rgba(255, 255, 255, 0.36);
		box-shadow: 0 24px 48px rgba(19, 34, 51, 0.12);
		backdrop-filter: blur(24px) saturate(150%);
	}
	.footer-title,
	.footer-copy,
	.footer-meta {
		margin: 0;
	}
	.footer-title {
		font-size: 1.1rem;
		font-weight: 700;
	}
	.footer-copy,
	.footer-meta {
		margin-top: 8px;
		color: var(--muted);
	}
	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin: 20px 0 0;
	}
	.footer-contact {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin: 16px 0 0;
	}
	.footer-nav a {
		padding: 0.72rem 1rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.24);
		border: 1px solid rgba(255, 255, 255, 0.3);
		text-decoration: none;
		color: var(--ink);
		backdrop-filter: blur(16px) saturate(150%);
	}
	.footer-nav a:hover {
		background: rgba(255, 255, 255, 0.38);
		border-color: rgba(255, 255, 255, 0.44);
		transform: translateY(-1px);
		box-shadow: 0 14px 24px rgba(19, 34, 51, 0.08);
	}
	.footer-contact a {
		color: var(--muted);
		text-decoration: none;
	}
	.footer-contact a:hover {
		color: var(--accent-strong);
	}
	@media (max-width: 720px) {
		.footer-shell {
			padding: 24px;
			border-radius: 24px;
		}
	}
</style>
